# Walmart Sales Forecasting - Environment Configuration
# Copy this file to .env.local and modify for your local setup

# Data Source Configuration
DATA_SOURCE=mongodb

# MongoDB Configuration
MONGO_URI=mongodb://localhost:27017
DB_NAME=walmart_sales

# HDFS Configuration (used when DATA_SOURCE=hdfs)
HDFS_HOST=localhost
HDFS_PORT=9870
HDFS_BASE=/user/walmart_sales

# For Docker internal network, use:
# MONGO_URI=mongodb://mongodb:27017
# HDFS_HOST=namenode
